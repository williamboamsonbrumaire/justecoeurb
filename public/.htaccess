# --------------------------------------------------------------------
# DEBUT DES REGLES DE REDIRECTION GLOBALE (A PLACER EN PREMIER)
# --------------------------------------------------------------------

# 1. FORCER LE HTTPS
# Redirige toute connexion HTTP vers HTTPS (crucial pour la securite et le SEO)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

# 2. FORCER LE DOMAINE PRINCIPAL (avec ou sans 'www')
# Cela s'assure que vous utilisez bien justecoeurb.ht et pas une autre variante.
# Exemple : Redirige www.justecoeurb.ht ou un autre domaine vers justecoeurb.ht
RewriteCond %{HTTP_HOST} !^justecoeurb\.ht$ [NC]
RewriteRule ^(.*)$ https://justecoeurb.ht/$1 [L,R=301]


# --------------------------------------------------------------------
# FIN DES REGLES DE REDIRECTION GLOBALE (NE PAS TOUCHER CI-DESSOUS)
# --------------------------------------------------------------------

# Activation du moteur de reecriture
RewriteEngine On
RewriteBase /

# 1. MASQUER L'EXTENSION .html (Reecriture interne)
# Si le chemin demande n'est pas un fichier reel et n'est pas un repertoire reel,
# verifier si un fichier .html existe.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# 2. MASQUER L'EXTENSION .php (Reecriture interne)
# Idem pour les fichiers .php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# 3. REDIRECTION (Optionnel mais Recommande pour le SEO)
# Rediriger l'ancienne URL avec l'extension vers la nouvelle URL propre.
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.+)\.(html|php)\ HTTP/
RewriteRule ^(.+)\.(html|php)$ /$1 [R=301,L]