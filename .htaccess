RewriteEngine On
# Remplacez /jcb/ par / si vous mettez le site en ligne à la racine
RewriteBase /jcb/

# --- 1. REDIRECTION PHYSIQUE (Pour cacher le dossier si on y accède) ---
RewriteCond %{THE_REQUEST} \s/jcb/pages/([^/\s]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# ── Cacher /blog/index.php → /blog ───────────────────────────────────────────
RewriteCond %{THE_REQUEST} \s/jcb/blog/index\.php [NC]
RewriteRule ^ /jcb/blog/ [R=301,L]

# ── /blog/slug → blog/blog-detail.php?slug=slug ──────────────────────────────
# On force la réécriture même si le dossier blog/ existe physiquement
RewriteCond %{REQUEST_URI} ^/jcb/blog/[a-z0-9][a-z0-9-]*/?$
RewriteCond %{REQUEST_URI} !^/jcb/blog/$
RewriteCond %{REQUEST_URI} !index\.php
RewriteRule ^blog/([a-z0-9][a-z0-9-]*)/?$ blog/blog-detail.php?slug=$1 [L,QSA]

# ── /blog ou /blog/ → blog/index.php ─────────────────────────────────────────
RewriteRule ^blog/?$ blog/index.php [L,QSA]

# --- 2. RÉÉCRITURE INTERNE : /page → pages/page.php -------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/jcb/pages/$1.php -f
RewriteRule ^([^/]+)$ pages/$1.php [L]

# --- 3. NETTOYAGE CLASSIQUE (.php manquant) ----------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]
